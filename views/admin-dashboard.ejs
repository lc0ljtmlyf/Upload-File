<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>پنل مدیریت - Upload Pro</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        [dir="ltr"] {
            direction: ltr;
        }
        
        .search-box {
            flex: 1;
            max-width: 400px;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 15px;
            cursor: pointer;
            padding: 10px 15px;
            border-radius: 8px;
            transition: all 0.3s;
        }

        .user-profile:hover {
            background: var(--light-bg);
        }

        body.dark-mode .user-profile:hover {
            background: var(--dark-bg);
        }

        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }

        .dropdown-menu {
            display: none;
            position: absolute;
            top: 100%;
            right: 0;
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            min-width: 200px;
            margin-top: 10px;
            z-index: 999;
        }

        body.dark-mode .dropdown-menu {
            background: var(--dark-bg-secondary);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .dropdown-menu.show {
            display: block;
        }

        .dropdown-menu a, .dropdown-menu button {
            display: block;
            width: 100%;
            padding: 12px 20px;
            border: none;
            background: none;
            text-align: right;
            cursor: pointer;
            color: var(--light-text);
            transition: all 0.3s;
            border-bottom: 1px solid var(--light-border);
        }

        body.dark-mode .dropdown-menu a,
        body.dark-mode .dropdown-menu button {
            color: var(--dark-text);
            border-bottom-color: var(--dark-border);
        }

        .dropdown-menu a:first-child, .dropdown-menu button:first-child {
            border-top-left-radius: 10px;
            border-top-right-radius: 10px;
        }

        .dropdown-menu a:last-child, .dropdown-menu button:last-child {
            border-bottom: none;
            border-bottom-left-radius: 10px;
            border-bottom-right-radius: 10px;
        }

        .dropdown-menu a:hover, .dropdown-menu button:hover {
            background: var(--light-bg);
        }

        body.dark-mode .dropdown-menu a:hover,
        body.dark-mode .dropdown-menu button:hover {
            background: var(--dark-bg);
        }

        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
        }

        .toggle-sidebar-btn {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--light-text);
        }

        body.dark-mode .toggle-sidebar-btn {
            color: var(--dark-text);
        }

        @media (max-width: 768px) {
            .toggle-sidebar-btn {
                display: block;
            }

            .navbar-left {
                gap: 10px;
            }

            .search-box {
                max-width: none;
            }
        }
    </style>
</head>
<body class="light-mode">

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <h2><i class="fas fa-cloud-upload-alt"></i> Upload Pro</h2>
            <p style="font-size: 0.8rem; opacity: 0.8;">پنل مدیریت</p>
        </div>
        <ul class="sidebar-menu">
            <li>
                <a href="#dashboard" onclick="showSection('dashboard')" class="menu-link active">
                    <i class="fas fa-chart-line"></i>
                    <span class="menu-text">داشبورد</span>
                </a>
            </li>
            <li>
                <a href="#users" onclick="showSection('users')" class="menu-link">
                    <i class="fas fa-users"></i>
                    <span class="menu-text">کاربران</span>
                </a>
            </li>
            <li>
                <a href="#files" onclick="showSection('files')" class="menu-link">
                    <i class="fas fa-folder-open"></i>
                    <span class="menu-text">فایل‌ها</span>
                </a>
            </li>
            <li>
                <a href="#analytics" onclick="showSection('analytics')" class="menu-link">
                    <i class="fas fa-analytics"></i>
                    <span class="menu-text">آمار</span>
                </a>
            </li>
            <li>
                <a href="#settings" onclick="showSection('settings')" class="menu-link">
                    <i class="fas fa-cog"></i>
                    <span class="menu-text">تنظیمات</span>
                </a>
            </li>
            <li style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;">
                <a href="/logout" class="menu-link">
                    <i class="fas fa-sign-out-alt"></i>
                    <span class="menu-text">خروج</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Navbar -->
        <div class="navbar">
            <div class="navbar-left">
                <button class="toggle-sidebar-btn" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <input type="text" placeholder="جستجو..." class="search-box" style="padding: 10px 15px; border: 1px solid var(--light-border); border-radius: 8px;">
            </div>
            <div class="navbar-right">
                <div class="lang-toggle">
                    <button class="lang-btn active" onclick="changeLanguage('fa')">فارسی</button>
                    <button class="lang-btn" onclick="changeLanguage('en')">English</button>
                </div>
                <button class="theme-toggle" onclick="toggleTheme()">
                    <i class="fas fa-moon"></i>
                </button>
                <div style="position: relative;">
                    <div class="user-profile" onclick="toggleDropdown()">
                        <div class="avatar">A</div>
                        <div>
                            <div style="font-weight: 600; font-size: 0.9rem;">Admin</div>
                            <div style="font-size: 0.8rem; opacity: 0.7;">مدیر</div>
                        </div>
                        <i class="fas fa-chevron-down" style="margin-right: 10px;"></i>
                    </div>
                    <div class="dropdown-menu" id="dropdownMenu">
                        <a href="#profile"><i class="fas fa-user"></i> پروفایل</a>
                        <a href="#settings"><i class="fas fa-cog"></i> تنظیمات</a>
                        <button onclick="logout()"><i class="fas fa-sign-out-alt"></i> خروج</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dashboard Section -->
        <div id="dashboard-section" class="section active">
            <h1 style="margin-bottom: 30px; font-size: 2rem; font-weight: 700;">
                <i class="fas fa-chart-line"></i> داشبورد
            </h1>

            <!-- Stats Grid -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <div class="stat-number" id="totalUsers">125</div>
                            <div class="stat-label">کل کاربران</div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-users"></i></div>
                    </div>
                </div>

                <div class="stat-card success">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <div class="stat-number" id="totalFiles">856</div>
                            <div class="stat-label">کل فایل‌ها</div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-file"></i></div>
                    </div>
                </div>

                <div class="stat-card warning">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <div class="stat-number" id="totalStorage">2.5GB</div>
                            <div class="stat-label">ذخیره استفاده‌شده</div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-database"></i></div>
                    </div>
                </div>

                <div class="stat-card info">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <div class="stat-number" id="activeDownloads">42</div>
                            <div class="stat-label">دانلودهای امروز</div>
                        </div>
                        <div class="stat-icon"><i class="fas fa-download"></i></div>
                    </div>
                </div>
            </div>

            <!-- Charts -->
            <div class="grid-2">
                <div class="card">
                    <h3 style="margin-bottom: 20px; font-size: 1.2rem; font-weight: 600;">
                        <i class="fas fa-chart-bar"></i> فعالیت هفتگی
                    </h3>
                    <div class="chart-container">
                        <canvas id="weeklyChart"></canvas>
                    </div>
                </div>

                <div class="card">
                    <h3 style="margin-bottom: 20px; font-size: 1.2rem; font-weight: 600;">
                        <i class="fas fa-pie-chart"></i> توزیع فایل‌ها
                    </h3>
                    <div class="chart-container">
                        <canvas id="fileTypeChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="card" style="margin-top: 30px;">
                <h3 style="margin-bottom: 20px; font-size: 1.2rem; font-weight: 600;">
                    <i class="fas fa-history"></i> فعالیت‌های اخیر
                </h3>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>نوع فعالیت</th>
                                <th>کاربر</th>
                                <th>فایل</th>
                                <th>زمان</th>
                                <th>وضعیت</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><i class="fas fa-upload" style="color: var(--success); margin-left: 10px;"></i> آپلود</td>
                                <td>علی محمدی</td>
                                <td>document.pdf</td>
                                <td>5 دقیقه پیش</td>
                                <td><span class="badge badge-success">موفق</span></td>
                            </tr>
                            <tr>
                                <td><i class="fas fa-download" style="color: var(--info); margin-left: 10px;"></i> دانلود</td>
                                <td>فاطمه احمدی</td>
                                <td>photo.jpg</td>
                                <td>12 دقیقه پیش</td>
                                <td><span class="badge badge-success">موفق</span></td>
                            </tr>
                            <tr>
                                <td><i class="fas fa-trash" style="color: var(--danger); margin-left: 10px;"></i> حذف</td>
                                <td>محمد رضا</td>
                                <td>video.mp4</td>
                                <td>1 ساعت پیش</td>
                                <td><span class="badge badge-success">موفق</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Users Section -->
        <div id="users-section" class="section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
                <h1 style="font-size: 2rem; font-weight: 700;">
                    <i class="fas fa-users"></i> مدیریت کاربران
                </h1>
                <button class="btn btn-primary" onclick="openUserModal()">
                    <i class="fas fa-plus"></i> کاربر جدید
                </button>
            </div>

            <div class="card">
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>نام کاربر</th>
                                <th>ایمیل</th>
                                <th>تاریخ عضویت</th>
                                <th>فایل‌ها</th>
                                <th>وضعیت</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody id="usersTable">
                            <tr>
                                <td>علی محمدی</td>
                                <td>ali@example.com</td>
                                <td>۱۴۰۲/۰۵/۱۵</td>
                                <td>12</td>
                                <td><span class="badge badge-success">فعال</span></td>
                                <td>
                                    <button class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.8rem;">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="btn btn-danger" style="padding: 6px 12px; font-size: 0.8rem;" onclick="deleteUser(this)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td>فاطمه احمدی</td>
                                <td>fateme@example.com</td>
                                <td>۱۴۰۲/۰۶/۲۰</td>
                                <td>8</td>
                                <td><span class="badge badge-success">فعال</span></td>
                                <td>
                                    <button class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.8rem;">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="btn btn-danger" style="padding: 6px 12px; font-size: 0.8rem;" onclick="deleteUser(this)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Files Section -->
        <div id="files-section" class="section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
                <h1 style="font-size: 2rem; font-weight: 700;">
                    <i class="fas fa-folder-open"></i> مدیریت فایل‌ها
                </h1>
                <select style="padding: 10px 15px; border-radius: 8px; border: 1px solid var(--light-border);">
                    <option>همه فایل‌ها</option>
                    <option>تصاویر</option>
                    <option>اسناد</option>
                    <option>ویدیو</option>
                    <option>موسیقی</option>
                </select>
            </div>

            <div class="card">
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>نام فایل</th>
                                <th>نوع</th>
                                <th>اندازه</th>
                                <th>کاربر</th>
                                <th>تاریخ</th>
                                <th>دانلودها</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><i class="fas fa-file-pdf" style="color: var(--danger); margin-left: 8px;"></i>document.pdf</td>
                                <td><span class="badge badge-info">PDF</span></td>
                                <td>2.5 MB</td>
                                <td>علی محمدی</td>
                                <td>۱۴۰۲/۰۵/۲۰</td>
                                <td>45</td>
                                <td>
                                    <button class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.8rem;">
                                        <i class="fas fa-download"></i>
                                    </button>
                                    <button class="btn btn-danger" style="padding: 6px 12px; font-size: 0.8rem;" onclick="deleteFile(this)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td><i class="fas fa-image" style="color: var(--warning); margin-left: 8px;"></i>photo.jpg</td>
                                <td><span class="badge badge-warning">IMAGE</span></td>
                                <td>1.8 MB</td>
                                <td>فاطمه احمدی</td>
                                <td>۱۴۰۲/۰۶/۱۵</td>
                                <td>82</td>
                                <td>
                                    <button class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.8rem;">
                                        <i class="fas fa-download"></i>
                                    </button>
                                    <button class="btn btn-danger" style="padding: 6px 12px; font-size: 0.8rem;" onclick="deleteFile(this)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Analytics Section -->
        <div id="analytics-section" class="section">
            <h1 style="margin-bottom: 30px; font-size: 2rem; font-weight: 700;">
                <i class="fas fa-chart-area"></i> آمار و گزارش‌ها
            </h1>

            <div class="grid-2">
                <div class="card">
                    <h3 style="margin-bottom: 20px; font-size: 1.2rem; font-weight: 600;">
                        <i class="fas fa-users-chart"></i> رشد کاربران
                    </h3>
                    <div class="chart-container">
                        <canvas id="userGrowthChart"></canvas>
                    </div>
                </div>

                <div class="card">
                    <h3 style="margin-bottom: 20px; font-size: 1.2rem; font-weight: 600;">
                        <i class="fas fa-database"></i> مصرف ذخیره‌سازی
                    </h3>
                    <div class="chart-container">
                        <canvas id="storageChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="card" style="margin-top: 30px;">
                <h3 style="margin-bottom: 20px; font-size: 1.2rem; font-weight: 600;">
                    <i class="fas fa-list"></i> خلاصه گزارش
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
                    <div style="padding: 15px; background: var(--light-bg); border-radius: 8px;">
                        <div style="font-size: 0.9rem; opacity: 0.7; margin-bottom: 8px;">میانگین دانلود روزانه</div>
                        <div style="font-size: 1.8rem; font-weight: 700; color: var(--primary);">325</div>
                    </div>
                    <div style="padding: 15px; background: var(--light-bg); border-radius: 8px;">
                        <div style="font-size: 0.9rem; opacity: 0.7; margin-bottom: 8px;">میانگین آپلود روزانه</div>
                        <div style="font-size: 1.8rem; font-weight: 700; color: var(--success);">156</div>
                    </div>
                    <div style="padding: 15px; background: var(--light-bg); border-radius: 8px;">
                        <div style="font-size: 0.9rem; opacity: 0.7; margin-bottom: 8px;">کاربران فعال ماهانه</div>
                        <div style="font-size: 1.8rem; font-weight: 700; color: var(--info);">892</div>
                    </div>
                    <div style="padding: 15px; background: var(--light-bg); border-radius: 8px;">
                        <div style="font-size: 0.9rem; opacity: 0.7; margin-bottom: 8px;">نرخ خرابی سیستم</div>
                        <div style="font-size: 1.8rem; font-weight: 700; color: var(--danger);">0.2%</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Settings Section -->
        <div id="settings-section" class="section">
            <h1 style="margin-bottom: 30px; font-size: 2rem; font-weight: 700;">
                <i class="fas fa-cog"></i> تنظیمات سیستم
            </h1>

            <div class="grid-2">
                <div class="card">
                    <h3 style="margin-bottom: 20px; font-size: 1.2rem; font-weight: 600;">
                        <i class="fas fa-server"></i> تنظیمات سرور
                    </h3>
                    <div class="form-group">
                        <label>حداکثر اندازه فایل (MB)</label>
                        <input type="number" value="500" style="width: 100%; padding: 10px; border: 1px solid var(--light-border); border-radius: 8px;">
                    </div>
                    <div class="form-group">
                        <label>محدودیت سرعت (MB/s)</label>
                        <input type="number" value="100" style="width: 100%; padding: 10px; border: 1px solid var(--light-border); border-radius: 8px;">
                    </div>
                    <div class="form-group">
                        <label>انقضای جلسه (دقیقه)</label>
                        <input type="number" value="30" style="width: 100%; padding: 10px; border: 1px solid var(--light-border); border-radius: 8px;">
                    </div>
                    <button class="btn btn-primary" style="width: 100%;"><i class="fas fa-save"></i> ذخیره تنظیمات</button>
                </div>

                <div class="card">
                    <h3 style="margin-bottom: 20px; font-size: 1.2rem; font-weight: 600;">
                        <i class="fas fa-shield-alt"></i> تنظیمات امنیتی
                    </h3>
                    <div class="form-group">
                        <label>
                            <input type="checkbox" checked> تایید دو مرحله‌ای
                        </label>
                    </div>
                    <div class="form-group">
                        <label>
                            <input type="checkbox" checked> رمزنگاری فایل‌ها
                        </label>
                    </div>
                    <div class="form-group">
                        <label>
                            <input type="checkbox"> محدود کردن IP
                        </label>
                    </div>
                    <div class="form-group">
                        <label>درجه امنیت</label>
                        <select style="width: 100%; padding: 10px; border: 1px solid var(--light-border); border-radius: 8px;">
                            <option>بالا</option>
                            <option>متوسط</option>
                            <option>پایین</option>
                        </select>
                    </div>
                    <button class="btn btn-primary" style="width: 100%;"><i class="fas fa-save"></i> ذخیره تنظیمات</button>
                </div>
            </div>

            <div class="card" style="margin-top: 30px;">
                <h3 style="margin-bottom: 20px; font-size: 1.2rem; font-weight: 600;">
                    <i class="fas fa-tools"></i> ابزارهای مدیریتی
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                    <button class="btn btn-secondary" style="padding: 12px; width: 100%;"><i class="fas fa-sync"></i> خالی کردن کش</button>
                    <button class="btn btn-secondary" style="padding: 12px; width: 100%;"><i class="fas fa-database"></i> بک‌آپ پایگاه داده</button>
                    <button class="btn btn-secondary" style="padding: 12px; width: 100%;"><i class="fas fa-check"></i> بررسی یکپارچگی</button>
                    <button class="btn btn-danger" style="padding: 12px; width: 100%; background: var(--danger); color: white;"><i class="fas fa-trash"></i> حذف فایل‌های موقت</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal" id="userModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>کاربر جدید</h3>
                <button class="close-btn" onclick="closeUserModal()">&times;</button>
            </div>
            <form onsubmit="addUser(event)">
                <div class="form-group">
                    <label>نام کاربر</label>
                    <input type="text" required>
                </div>
                <div class="form-group">
                    <label>ایمیل</label>
                    <input type="email" required>
                </div>
                <div class="form-group">
                    <label>رمز عبور</label>
                    <input type="password" required>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button type="submit" class="btn btn-primary" style="flex: 1;">
                        <i class="fas fa-plus"></i> افزودن
                    </button>
                    <button type="button" class="btn btn-secondary" style="flex: 1;" onclick="closeUserModal()">
